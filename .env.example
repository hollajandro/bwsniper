# ─────────────────────────────────────────────────────────────────────────────
# BuyWander Sniper — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then start the stack:
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing secret.  Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# ── Strongly recommended ──────────────────────────────────────────────────────

# Fernet encryption key for stored BuyWander passwords.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank, one is auto-generated and written to /data/fernet.key on first
# start — but you must back that file up or your stored credentials become
# unreadable if the container is recreated.
FERNET_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# BuyWander's Stripe publishable key.
# Optional — the backend auto-discovers this from BuyWander's checkout page at
# runtime using the authenticated session, so you normally don't need to set it.
# Only set this if auto-discovery fails (e.g. BuyWander changes their page layout).
STRIPE_PUBLISHABLE_KEY=

# Google Shopping price comparison via Serper.dev.
# Free tier gives 2,500 searches/month: https://serper.dev
SERPER_API_KEY=

# CORS — comma-separated list of origins allowed to call the API.
# Set to the URL your browser uses to reach the frontend.
# Default: http://localhost  (fine for local single-machine use)
CORS_ORIGINS=http://localhost

# Port the web UI listens on (default: 80).
WEB_PORT=80

# Uvicorn worker count for the backend (default: 2).
# Rule of thumb: 2 × CPU cores + 1.  Don't set too high for SQLite.
WEB_CONCURRENCY=2

# Token lifetimes (defaults shown).
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# REFRESH_TOKEN_EXPIRE_DAYS=30
