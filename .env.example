# ─────────────────────────────────────────────────────────────────────────────
# BwSniper — Environment Configuration Example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then start the stack:
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Security Keys (REQUIRED) ─────────────────────────────────────────────────
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Generate FERNET_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your-secret-key-here
FERNET_KEY=your-fernet-key-here

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=bwsniper123

# ── Redis ────────────────────────────────────────────────────────────────────
# Redis is configured in docker-compose.yml, no additional env vars needed

# ── Frontend ─────────────────────────────────────────────────────────────────
WEB_PORT=80
CORS_ORIGINS=http://localhost

# ── Optional Features ────────────────────────────────────────────────────────
# Serper.dev API key for Google Shopping price comparison
SERPER_API_KEY=

# OpenTelemetry exporter endpoint (e.g., http://jaeger:4317)
OTEL_EXPORTER_ENDPOINT=

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Number of Uvicorn worker processes
WEB_CONCURRENCY=2

# ── Token Lifetimes (Optional Overrides) ─────────────────────────────────────
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# REFRESH_TOKEN_EXPIRE_DAYS=30
