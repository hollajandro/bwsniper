# -----------------------------------------------------------------------------
# BwSniper - Environment Configuration Example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then start the stack:
#   docker compose up -d
# -----------------------------------------------------------------------------

# Docker image configuration (optional)
# These control which pre-built images are pulled from GHCR.io.
# Override these if you use a custom registry, repository name, or tag.
REGISTRY=ghcr.io
IMAGE_NAME=your-username/bwsniper
TAG=latest

# Security keys (required)
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Generate FERNET_KEY with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your-secret-key-here
FERNET_KEY=your-fernet-key-here

# Database
POSTGRES_PASSWORD=bwsniper123

# Full DATABASE_URL for migrations and direct PostgreSQL access.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://bwsniper:bwsniper123@db:5432/bwsniper

# Redis
# Redis is configured in docker-compose.yml. No additional env vars are required
# for the default Docker Compose stack.

# Frontend
WEB_PORT=80
CORS_ORIGINS=http://localhost

# Optional features
# Serper.dev API key for Google Shopping price comparison.
SERPER_API_KEY=

# OpenTelemetry exporter endpoint, for example http://jaeger:4317.
OTEL_EXPORTER_ENDPOINT=

# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Number of Uvicorn worker processes.
WEB_CONCURRENCY=2

# Token lifetimes (optional overrides)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Remote redundancy agent (optional)
# Enable the optional Compose service with:
#   docker compose --profile redundancy up -d remote-agent
#
# Provisioning flow:
#   1. Sign in as an admin.
#   2. Open Admin -> Remote Agents.
#   3. Create an agent and copy the one-time API key.
#   4. Set REMOTE_AGENT_ID and REMOTE_AGENT_API_KEY on the remote host.
#   5. Assign the agent to specific users and enable redundancy in Admin.
#
# For true redundancy, run the remote-agent service on separate infrastructure
# and point MAIN_BACKEND_URL at the public HTTPS URL of the main backend.
MAIN_BACKEND_URL=http://backend:8000
REMOTE_AGENT_ID=
REMOTE_AGENT_API_KEY=
REMOTE_AGENT_POLL_INTERVAL_MS=3000
